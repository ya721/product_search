flowchart TD
    A[エスカレーション完了] --> B[必須記録事項作成]
    
    subgraph "記録内容"
        B --> C[基本情報<br/>記録ID・発生フェーズ・発見者・日時]
        B --> D[問題詳細<br/>分類・緊急度・影響範囲・内容]
        B --> E[エスカレーション経路<br/>Phase1-3の判定結果]
        B --> F[解決策<br/>採用案・代替案・実装方針]
        B --> G[教訓・改善点<br/>予防策・ナレッジ更新]
    end
    
    C --> H[品質保証チェック]
    D --> H
    E --> H
    F --> H
    G --> H
    
    subgraph "品質チェック項目"
        H --> I[問題の本質特定確認]
        H --> J[全関係者意見収集確認]
        H --> K[外部検証実施確認]
        H --> L[プロセス透明性確認]
        H --> M[決定内容実装可能性確認]
        H --> N[モニタリング計画設定確認]
        H --> O[予防策検討確認]
    end
    
    I --> P[月次レビュー]
    J --> P
    K --> P
    L --> P
    M --> P
    N --> P
    O --> P
    
    subgraph "継続的改善分析"
        P --> Q[発生頻度・傾向分析]
        P --> R[解決時間・SLA達成率]
        P --> S[管理者判断一致率]
        P --> T[外部検証精度評価]
        P --> U[プロジェクト影響度評価]
    end
    
    Q --> V[改善アクション策定]
    R --> V
    S --> V
    T --> V
    U --> V
    
    subgraph "改善実行"
        V --> W[頻発問題パターンの<br/>ガイドライン化]
        V --> X[管理者専門領域境界<br/>明確化]
        V --> Y[エスカレーション基準<br/>調整]
        V --> Z[ツール・プロセス<br/>最適化]
    end
    
    W --> AA[次期プロジェクトへ反映]
    X --> AA
    Y --> AA
    Z --> AA
    
    AA --> BB[ナレッジベース更新]
    BB --> CC[エスカレーション手順改訂]
    
    style A fill:#ffcccc
    style H fill:#cce5ff
    style P fill:#ffffcc
    style V fill:#ccffcc
    style AA fill:#e6ccff