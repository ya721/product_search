graph TB
    subgraph "Phase 1: 専門管理者レベル（15分以内）"
        A1[問題受領] --> B1[初期分析]
        B1 --> C1[問題分類:<br/>技術的/設計的/品質的/セキュリティ的]
        C1 --> D1[専門領域判定:<br/>領域内/境界線上/領域外]
        D1 --> E1[緊急度評価:<br/>低/中/高/緊急]
        E1 --> F1[影響範囲評価:<br/>局所的/モジュール的/システム全体]
        F1 --> G1{自己解決可能性判定}
        G1 -->|可能| H1[解決策実装]
        G1 -->|困難| I1[エスカレーション判定]
    end

    subgraph "Phase 2: 管理者間協議レベル（1時間以内）"
        A2[協議招集] --> B2[参加者決定]
        B2 --> C2[各管理者見解収集]
        C2 --> D2[クリーンアーキテクチャ管理者見解]
        C2 --> E2[TDD管理者見解]
        C2 --> F2[セキュリティ管理者見解]
        C2 --> G2[その他関連管理者見解]
        D2 --> H2[合意形成プロセス]
        E2 --> H2
        F2 --> H2
        G2 --> H2
        H2 --> I2{合意状況判定}
        I2 -->|一致| J2[合意による解決]
        I2 -->|対立| K2[上位エスカレーション]
    end

    subgraph "Phase 3: プロジェクトレベル（1時間以内）"
        A3[統合判断開始] --> B3[全情報統合]
        B3 --> C3[管理者見解サマリー作成]
        C3 --> D3[外部検証実施<br/>Claude連携]
        D3 --> E3[技術的妥当性評価]
        D3 --> F3[業界ベストプラクティス比較]
        D3 --> G3[総合リスク分析]
        E3 --> H3[最終判断基準適用]
        F3 --> H3
        G3 --> H3
        H3 --> I3[プロジェクト成功への影響度]
        H3 --> J3[セキュリティ・品質リスク]
        H3 --> K3[実装コストと期間]
        H3 --> L3[保守性・拡張性]
        H3 --> M3[チームスキル適合性]
        I3 --> N3[最終決定]
        J3 --> N3
        K3 --> N3
        L3 --> N3
        M3 --> N3
    end

    I1 --> A2
    K2 --> A3
    H1 --> O[記録・改善]
    J2 --> O
    N3 --> O

    style A1 fill:#cce5ff
    style A2 fill:#ffffcc
    style A3 fill:#ccffcc
    style O fill:#e6ccff